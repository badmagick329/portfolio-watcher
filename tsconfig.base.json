{
  "compilerOptions": {
    "allowJs": true,
    "moduleResolution": "bundler",
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noPropertyAccessFromIndexSignature": false,
    "paths": {
      "@portfolio/domain": ["./packages/domain/src/index.ts"],
      "@portfolio/infra": ["./packages/infra/src/index.ts"],
      "@portfolio/use-cases": ["./packages/use-cases/src/index.ts"],
      "@portfolio/composition": ["./packages/composition/src/index.ts"]
    }
  }
}
